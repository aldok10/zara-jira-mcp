# Jira connection (required)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token

# AI provider (OpenAI-compatible endpoint)
JIRA_AI_BASE_URL=https://api.openai.com
JIRA_AI_API_KEY=sk-...
JIRA_AI_MODEL=gpt-4o-mini

# Lark webhook (optional, for notifications)
JIRA_LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx

# PM Memory (optional, default: ~/.zara-jira-mcp/pm_memory.db)
# PM_MEMORY_DB_PATH=/custom/path/to/pm_memory.db

# Lark SDK (full API access — optional, overrides webhook)
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=your-app-secret
LARK_CHAT_ID=oc_xxx

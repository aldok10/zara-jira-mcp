# Jira connection (required)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token

# Server transport (optional, default: stdio)
# MCP_TRANSPORT=stdio  # stdio | sse | http
# MCP_PORT=8080        # port for sse/http mode

# Tool profile (controls how many tools are registered)
# PM_PROFILE=lite      # ~30 tools: Jira + PM essentials (fastest, for ChatGPT/slow clients)
# PM_PROFILE=standard  # ~80 tools: + AI + notifications (recommended for daily use)
# PM_PROFILE=full      # ~150 tools: + stakeholder + portfolio + github
# (default: all ~224 tools, or use PM_ENABLED_MODULES=jira,pm,ai for custom)

# AI provider — auto-detected from base URL
# Supports: OpenAI-compatible, Anthropic (Claude), Google Gemini
JIRA_AI_BASE_URL=https://api.openai.com
JIRA_AI_API_KEY=sk-...
JIRA_AI_MODEL=gpt-4o-mini

# --- Provider examples (uncomment one) ---
#
# OpenAI
# JIRA_AI_BASE_URL=https://api.openai.com
# JIRA_AI_API_KEY=sk-proj-...
# JIRA_AI_MODEL=gpt-4o-mini
#
# Anthropic (Claude)
# JIRA_AI_BASE_URL=https://api.anthropic.com
# JIRA_AI_API_KEY=sk-ant-...
# JIRA_AI_MODEL=claude-sonnet-4-20250514
#
# Google Gemini
# JIRA_AI_BASE_URL=https://generativelanguage.googleapis.com
# JIRA_AI_API_KEY=AIza...
# JIRA_AI_MODEL=gemini-2.5-flash
#
# Groq (free tier)
# JIRA_AI_BASE_URL=https://api.groq.com/openai
# JIRA_AI_API_KEY=gsk_...
# JIRA_AI_MODEL=llama-3.3-70b-versatile
#
# Ollama (local, free)
# JIRA_AI_BASE_URL=http://localhost:11434
# JIRA_AI_API_KEY=ollama
# JIRA_AI_MODEL=llama3.2
#
# OpenRouter (100+ models)
# JIRA_AI_BASE_URL=https://openrouter.ai/api
# JIRA_AI_API_KEY=sk-or-...
# JIRA_AI_MODEL=anthropic/claude-sonnet-4-20250514
#
# Together.ai
# JIRA_AI_BASE_URL=https://api.together.xyz
# JIRA_AI_API_KEY=...
# JIRA_AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#
# DeepSeek
# JIRA_AI_BASE_URL=https://api.deepseek.com
# JIRA_AI_API_KEY=sk-...
# JIRA_AI_MODEL=deepseek-chat

# PM Memory (optional, default: ~/.zara-jira-mcp/pm_memory.db)
# PM_MEMORY_DB_PATH=/custom/path/to/pm_memory.db

# --- Notification Platforms (all optional) ---

# Lark webhook (simple)
JIRA_LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx

# Lark SDK (full API, overrides webhook)
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=your-app-secret
LARK_CHAT_ID=oc_xxx

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_DEFAULT_CHANNEL=general
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=123456789
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-1001234567890

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=pm@company.com

# --- Documentation ---

# Confluence
CONFLUENCE_BASE_URL=https://your-company.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-token
